@using LMSProject.Areas.Instructor.ViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Grade-Create";
}
@section Styles
{
    <link rel="stylesheet" href="~/Admin/assets/vendors/jquery-toast-plugin/jquery.toast.min.css">
}
@model CourseGroupVM
<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adding Group Data</h4>
            <p class="card-description"> Insert Group Data </p>
            <form asp-area="Instructor" class="forms-sample" method="post" enctype="multipart/form-data">
                <div class="form-group row">
                    
                    <label asp-for="Courses" class="col-sm-3 col-form-label">Select Course</label>
                    <div class="col-sm-9">
                        <select id="CourseId" name="CourseId" class="form-check form-control">
                            @foreach (var item in Model.Courses)
                            {
                             
                                <option value="@item.Id">@item.Name</option>
                             
                            }
                        </select>
                        
                    </div>

                </div>
                <div class="form-group row">
                    
                    <label asp-for="GroupName" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="GroupName">
                        <span asp-validation-for="GroupName" class="text-danger"></span>
                    </div>

                </div>
                
                <div class="form-group row">
                    
                    <label asp-for="Capacity" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="Capacity">
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>

                </div>
                
                <div class="form-group row">
                    <label asp-for="StartDate" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="StartDate"
                               type="date"
                               class="form-control" />
                        <span asp-validation-for="StartDate"
                              class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group row">
                    <label asp-for="EndDate" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="EndDate"
                               type="date"
                               class="form-control" />
                        <span asp-validation-for="EndDate"
                              class="text-danger"></span>
                    </div>
                </div> <button type="submit" onclick="" class="btn btn-gradient-primary me-2">Submit</button>
               
            </form>
        </div>
    </div>
</div>
<!-- Custom js for this page -->
@section Scripts {
    @{
        <script src="~/Admin/assets/vendors/jquery-toast-plugin/jquery.toast.min.js"></script>
        <script src="~/Admin/assets/js/toastDemo.js"></script>

        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
        @if (ViewBag.Messag != null)
        {
            <script type="text/javascript">
                showSuccessToast();
            </script>
        }

            
    }
    <!-- End custom js for this page -->
}
