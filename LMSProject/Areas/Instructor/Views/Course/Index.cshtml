@using MLSCore.Models
@model List<TbCourse>

@{
    ViewData["Title"] = "Course-List";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Course List</h4>
            <p class="card-description">
                Add Course <code><a asp-controller="Course" asp-action="Create">.Add New</a></code>
            </p>
            <table class="table table-striped">
                <tr>
                    <th>Image</th>
                    <th>Course</th>
                    <th>Created By</th>
                    <th>Current State</th>
       
                    <th>Action</th>
                </tr>
                @foreach (var course in Model)
                {
                    <tr>
                        <td><img src="~/@course.ImageName" width="100px" /></td>
                        <td>@course.Name</td>
                        <td>@course.CreatedBy</td>
                        <td><input type="checkbox" checked="@course.CurrentState"></td>
           
                        <td>
                             <a class="badge badge-success" asp-action="Details" asp-route-id="@course.Id">Details</a>
                            <a class="badge badge-info" asp-action="Edit" asp-route-id="@course.Id">Edit</a>
                            <button class="badge badge-danger" onclick="showSwal('@course.Id','Course');">Delete</button>
                            
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @{
        <script src="~/Admin/assets/vendors/sweetalert/sweetalert.min.js"></script>
        <script src="~/Admin/assets/vendors/jquery.avgrund/jquery.avgrund.min.js"></script>
        <script src="~/Admin/assets/js/alerts.js"></script>
        <script src="~/Admin/assets/js/avgrund.js"></script>
        <script>
            (function ($) {
                showSwal = function (type,url) {
                    alert(type);
                    'use strict';
                    swal({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',,yu
                        showCancelButton: true,
                        confirmButtonColor: '#3f51b5',
                        cancelButtonColor: '#ff4081',
                        confirmButtonText: 'Great ',
                        buttons: {
                            cancel: {
                                text: "Cancel",
                                value: null,
                                visible: true,
                                className: "btn btn-danger",
                                closeModal: true,
                            },
                            confirm: {
                                text: "OK",
                                value: true,
                                visible: true,
                                className: "btn btn-primary",
                                closeModal: true
                            }
                        }
                    }).then(function (isConfirm) {
                                if (isConfirm) {alert('?Id=' + type);
                             window.location.href = '@Url.Action("Delete", "Courseu ")?Id=' + type;
                        
                        } else {
                            swal("Cancelled", "Your imaginary file is safe :)", "error");
                        }
                    })


                }

            })(jQuery);
        </script>
    }

    <!-- End custom js for this page -->
}