@model IEnumerable<MLSCore.Models.TbTask>

@{
    ViewData["Title"] = "Task Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="h2 fw-bold text-dark">
                <i class="bi bi-list-check me-2"></i> Task Management
            </h2>
            <p class="text-muted">Create, manage, and grade student tasks</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle me-2"></i> Create New Task
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tasks Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model.Count() == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                    <p class="text-muted mt-3">No tasks created yet. Start by creating your first task!</p>
                    <a asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-2"></i> Create Task
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light border-bottom">
                            <tr>
                                <th class="ps-4 fw-bold">Task Title</th>
                                <th class="fw-bold">Sub-Content</th>
                                <th class="fw-bold">Course</th>
                                <th class="fw-bold">Start Date</th>
                                <th class="fw-bold">End Date</th>
                                <th class="fw-bold">Created</th>
                                <th class="fw-bold text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model)
                            {
                                <tr class="border-bottom">
                                    <td class="ps-4">
                                        <div class="fw-semibold text-dark">@task.Title</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">@task.SubContent?.Title</span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@task.SubContent?.CourseContent?.Course?.Name</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @task.StartDate.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @task.EndDate.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @task.CreatedDate?.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <!-- View Submissions Button -->
                                            <a asp-action="Submissions" asp-route-taskId="@task.Id" 
                                               class="btn btn-sm btn-outline-info" title="View Submissions">
                                                <i class="bi bi-eye"></i> Submissions
                                            </a>

                                            <!-- Edit Button -->
                                            <a asp-action="Edit" asp-route-id="@task.Id" 
                                               class="btn btn-sm btn-outline-warning" title="Edit Task">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="Delete" asp-route-id="@task.Id" 
                                               class="btn btn-sm btn-outline-danger" title="Delete Task">
                                                <i class="bi bi-trash"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }

    .btn-group {
        display: flex;
        gap: 0.25rem;
    }

    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
    }
</style>

