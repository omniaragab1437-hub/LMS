@using MLSCore.DTO
@model List<InstructorCoursesDTO>

@{
    ViewData["Title"] = "Instructor-List";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Instructor List</h4>
            <p class="card-description">
                Add Instructor <code><a asp-controller="Instructor" asp-action="Register">.Add New</a></code>
            </p>
            <table class="table table-striped">
                <tr>
                    <th>Image</th>
                    <th>Full Name</th>
                    <th>Specialization</th>
                    <th>Current State</th>
                    <th>Courses</th>
                    <th>Action</th>
                </tr>
                @foreach (var instr in Model)
                {
                    <tr>
                        <td><img src="~/@instr.Image" width="100px" /></td>
                        <td>@instr.FullName</td>
                        <td>@instr.Specialization</td>
                        <td><input type="checkbox" checked="@instr.CurrentState"></td>
                        <td>@instr.Courses</td>
                        <td>
                           
                            <a asp-area="Admin" class="badge badge-info" asp-action="Edit" asp-route-id="@instr.Id">Edit</a>
                            <a asp-area="Admin"  class="badge badge-info" asp-action="Details" asp-route-id="@instr.Id">Details</a>
                            <button class="badge badge-danger" onclick="showSwal('@instr.Id','Instructor');">Delete</button>
                            
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @{
        <script src="~/Admin/assets/vendors/sweetalert/sweetalert.min.js"></script>
        <script src="~/Admin/assets/vendors/jquery.avgrund/jquery.avgrund.min.js"></script>
        <script src="~/Admin/assets/js/alerts.js"></script>
        <script src="~/Admin/assets/js/avgrund.js"></script>
        <script>
            (function ($) {
                showSwal = function (type,url) {
                    alert(type);
                    'use strict';
                    swal({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#3f51b5',
                        cancelButtonColor: '#ff4081',
                        confirmButtonText: 'Great ',
                        buttons: {
                            cancel: {
                                text: "Cancel",
                                value: null,
                                visible: true,
                                className: "btn btn-danger",
                                closeModal: true,
                            },
                            confirm: {
                                text: "OK",
                                value: true,
                                visible: true,
                                className: "btn btn-primary",
                                closeModal: true
                            }
                        }
                    }).then(function (isConfirm) {
                                if (isConfirm) {alert('?Id=' + type);
                             window.location.href = '@Url.Action("Delete", "Instructor")?Id=' + type;
                        
                        } else {
                            swal("Cancelled", "Your imaginary file is safe :)", "error");
                        }
                    })


                }

            })(jQuery);
        </script>
    }

    <!-- End custom js for this page -->
}