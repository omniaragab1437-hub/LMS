@using LMSProject.Areas.Admin.ViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Instructor-Register";
}
@section Styles
{
    <link rel="stylesheet" href="~/Admin/assets/vendors/jquery-toast-plugin/jquery.toast.min.css">
}
@model InstructorEditVM
<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adding Instructor Data</h4>
            <p class="card-description"> Instructor Data </p>
            <form class="forms-sample" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>
                <input asp-for="ImageName" type="hidden" />
                
                <div class="form-group row">
                    
                    <label asp-for="FullName" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="FullName">
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    
                    <label asp-for="UserName" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="UserName">
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                </div>
              
                <div class="form-group row">
                    
                    <label asp-for="Email" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="Email">
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                </div>
              
                <div class="form-group row">
                    
                    <label asp-for="PhoneNumber" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="PhoneNumber">
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    <label class=" col-sm-3 col-form-label">
                        Show In Home Page
                    </label>
                    <div class="col-sm-9">
                        <input type="checkbox" asp-for="ShowInHomePage" class="form-check-input"><i class="input-helper"></i>
                    </div>
                </div>
                <div class="form-group row">
                    
                    <label asp-for="Password" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="Password">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    
                    <label asp-for="Bio" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="Bio">
                        <span asp-validation-for="Bio" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    
                    <label asp-for="Specialization" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="Specialization">
                        <span asp-validation-for="Specialization" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    
                    <label asp-for="ExperienceYears" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input type="text" class="form-control" asp-for="ExperienceYears">
                        <span asp-validation-for="ExperienceYears" class="text-danger"></span>
                    </div>

                </div>
                <div class="form-group row">
                    <label class=" col-sm-3 col-form-label">
                        Upload Image
                    </label>
                    <div class="col-sm-9">
                        <input asp-for="Image" type="file"
                               class="form-control" placeholder="Uplad Image"
                               accept=".jpg, .jpeg, .png, ,.gif">

                    </div>
                </div>
                
                <button type="submit" onclick="" class="btn btn-gradient-primary me-2">Submit</button>
               
            </form>
        </div>
    </div>
</div>
<!-- Custom js for this page -->
@section Scripts {
    @{
        <script src="~/Admin/assets/vendors/jquery-toast-plugin/jquery.toast.min.js"></script>
        <script src="~/Admin/assets/js/toastDemo.js"></script>
        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
        
        @if (ViewBag.Messag != null)
        {
            <script type="text/javascript">
                showSuccessToast();
            </script>
        }

            
    }
    <!-- End custom js for this page -->
}
