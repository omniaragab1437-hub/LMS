<footer class="footer-section py-5 mt-5">
    <div class="container text-center">

        <!-- Logo and Slogan -->
        <div class="d-flex justify-content-center align-items-center gap-3 mb-5 mt-4">
            <div class="footer-logo">
                <img src="~/Images/images/logo_white.png" class="logo-box" alt="TOTC Logo" style="height: 50px;">
            </div>
            <div class="vr bg-light opacity-50" style="height: 40px; width: 1.5px;"></div>
            <span class="text-white fw-medium fs-5 text-start">Virtual Class<br>for Zoom</span>
        </div>

        <!-- Newsletter Section -->
        <form asp-controller="Home" asp-action="Subscribe" method="post" class="newsletter-container mx-auto mb-5">
            <h5 class="text-white-50 mb-4 fw-normal">Subscribe to get our Newsletter</h5>
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <input type="email" name="email" class="form-control newsletter-input" placeholder="Your Email" required>
                <button type="submit" class="btn btn-subscribe rounded-pill px-5 py-2">Subscribe</button>
            </div>
        </form>

        <!-- Footer Links -->
        <div class="footer-links d-flex justify-content-center gap-3 gap-md-4 mb-3">
            <a asp-controller="Home" asp-action="Careers" class="text-white-50 text-decoration-none">Careers</a>
            <span class="text-white-50">|</span>
            <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none">Privacy Policy</a>
            <span class="text-white-50">|</span>
            <a href="#" class="text-white-50 text-decoration-none">Terms & Conditions</a>
        </div>

        <!-- Copyright -->
        <p class="text-white-50 small mb-0">© @DateTime.Now.Year Class Technologies Inc.</p>

    </div>
</footer>
