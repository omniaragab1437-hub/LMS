@{
    Layout = "_Layout";
}

<!-- <img src="/imgs/header-bg.png" alt="" class="w-100"> -->
<section class="hero d-flex align-items-center">
    <div class="container pt-5">
        <div class="row align-items-center">

            <div class="col-md-6 text-white">
                <h1 class="fw-bold">
                    <span class="text-orange">Studying</span>
                    Online is now <br> much easier
                </h1>

                <p class="mt-3">
                    TOTC is an interesting platform that will teach you in more interactive way
                </p>

                <div class="d-flex gap-3 mt-4">
                    <button class="btn btn-light rounded-pill px-4">Join for free</button>

                    <div class="d-flex align-items-center gap-2">
                        <div class="play-btn">
                            <i class="fa-solid fa-play"></i>
                        </div>
                        <span>Watch how it works</span>
                    </div>
                </div>
            </div>

            <div class="col-md-6 text-center">
                <img src="~/Images/images/hero.png" class="img-fluid hero-img">
            </div>

        </div>
    </div>
</section>

<section class="success py-5 text-center">
    <div class="container">

        <!-- TITLE -->
        <h2 class="fw-bold mb-3 fade-up">Our Success</h2>

        <p class="text-muted w-50 mx-auto fade-up delay-1">
            Ornare id fames interdum porttitor nulla turpis etiam. Diam vitae sollicitudin at nec nam et pharetra
            gravida.
        </p>

        <!-- STATS -->
        <div class="row mt-5 justify-content-center g-4">

            <div class="col-6 col-md-2 fade-up delay-1">
                <div class="stat-box">
                    <h3>15K+</h3>
                    <p>Students</p>
                </div>
            </div>

            <div class="col-6 col-md-2 fade-up delay-2">
                <div class="stat-box">
                    <h3>75%</h3>
                    <p>Total success</p>
                </div>
            </div>

            <div class="col-6 col-md-2 fade-up delay-3">
                <div class="stat-box">
                    <h3>35</h3>
                    <p>Main questions</p>
                </div>
            </div>

            <div class="col-6 col-md-2 fade-up delay-4">
                <div class="stat-box">
                    <h3>26</h3>
                    <p>Chief experts</p>
                </div>
            </div>

            <div class="col-6 col-md-2 fade-up delay-5">
                <div class="stat-box">
                    <h3>16</h3>
                    <p>Years of experience</p>
                </div>
            </div>

        </div>

    </div>
</section>

<section class="features py-5 text-center">
    <div class="container">

        <h3 class="fw-bold">
            All-In-One <span class="text-info-custom">Cloud Software</span>
        </h3>

        <p class="text-muted mt-2">
            TOTC is one powerful online software suite that combines all tools
        </p>

        <div class="row mt-5 g-4">

            <!-- CARD 1 -->
            <div class="col-md-4">
                <div class="card feature-card p-4 border-0 h-100">

                    <div class="icon-box icon-blue">
                        <i class="fa-solid fa-file-invoice"></i>
                    </div>

                    <h5 class="mt-4 fw-bold">Online Billing, Invoicing, & Contracts</h5>

                    <p class="text-muted">
                        Simple and secure control of your organization’s financial and legal transactions.
                    </p>

                </div>
            </div>

            <!-- CARD 2 -->
            <div class="col-md-4">
                <div class="card feature-card p-4 border-0 h-100">

                    <div class="icon-box icon-green">
                        <i class="fa-solid fa-calendar-check"></i>
                    </div>

                    <h5 class="mt-4 fw-bold">Easy Scheduling & Attendance Tracking</h5>

                    <p class="text-muted">
                        Schedule and reserve classrooms and track student attendance easily.
                    </p>

                </div>
            </div>

            <!-- CARD 3 -->
            <div class="col-md-4">
                <div class="card feature-card p-4 border-0 h-100">

                    <div class="icon-box icon-purple">
                        <i class="fa-solid fa-users"></i>
                    </div>

                    <h5 class="mt-4 fw-bold">Customer Tracking</h5>

                    <p class="text-muted">
                        Automate and track emails to individuals or groups and manage engagement.
                    </p>

                </div>
            </div>

        </div>

    </div>
</section>
<section class="py-5 text-center">
    <div class="container">
        <!-- Title with --primary color -->
        <h3 class="fw-bold mb-3" style="color: var(--primary);">
            What is <span style="color: var(--secondary);">TOTC?</span>
        </h3>
        <p class="text-muted mb-5 mx-auto" style="max-width: 700px;">
            TOTC is a platform that allows educators and learners to connect, collaborate, and grow together in a modern
            learning environment.
        </p>

        <div class="row g-4 justify-content-center">
            <!-- Instructors Card -->
            <div class="col-md-5">
                <div class="card border-0 shadow-none position-relative overflow-hidden rounded-4">
                    <div class="card-image-wrapper">
                        <img src="~/Images/images/wt2.png" class="img-fluid rounded-4" alt="Instructors">
                        <div class="card-overlay-content">
                            <h4 class="text-white fw-bold mb-3">FOR INSTRUCTORS</h4>
                            <button class="btn btn-overlay btn-outline-light rounded-pill px-4 py-2"
                                    routerLink="/login">
                                Start a class
                                today
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Students Card -->
            <div class="col-md-5">
                <div class="card border-0 shadow-none position-relative overflow-hidden rounded-4">
                    <div class="card-image-wrapper">
                        <img src="~/Images/images/wt1.png" class="img-fluid rounded-4" alt="Students">
                        <div class="card-overlay-content">
                            <h4 class="text-white fw-bold mb-3">FOR STUDENTS</h4>
                            <button class="btn btn-primary-alt rounded-pill px-4 py-2" routerLink="/login">
                                Enter access
                                code
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-md-6">
                <h4 class="fw-bold">
                    Everything you can do in a physical classroom
                </h4>
                <p class="text-muted">
                    TOTC allows you to replicate and enhance classroom experiences online with powerful tools.
                </p>
                <ul class="list-unstyled">
                    <li class="mb-2">✔ Interactive lessons</li>
                    <li class="mb-2">✔ Real-time collaboration</li>
                    <li class="mb-2">✔ Student engagement tracking</li>
                </ul>
            </div>

            <div class="col-md-6">
                <img src="~/Images/images/physical.png" class="img-fluid rounded shadow" alt="">
            </div>

        </div>
    </div>
</section>
<section class="py-5" style="background-color: var(--bg-light);">
    <div class="container">
        <!-- Section Header -->
        <div class="text-center mb-5">
            <h2 class="fw-bold" style="color: var(--primary);">
                Our <span style="color: var(--secondary);">Features</span>
            </h2>
            <p class="text-muted">This very extraordinary feature can make learning activities more efficient</p>
        </div>

        <div class="row align-items-center g-5">
            <!-- Text Content -->
            <div class="col-md-6 text-start">
                <h3 class="fw-bold mb-4" style="color: var(--primary); line-height: 1.4;">
                    A <span style="color: var(--secondary);">user interface</span> designed for the classroom
                </h3>

                <ul class="list-unstyled feature-list">
                    <li class="d-flex align-items-start mb-4">
                        <div class="icon-box shadow-sm me-3" style="background-color: white; color: var(--secondary);">
                            <i class="fas fa-th-large"></i>
                        </div>
                        <p class="mb-0 text-muted">
                            Teachers and students can each customize their dashboard with
                            settings they need most.
                        </p>
                    </li>

                    <li class="d-flex align-items-start mb-4">
                        <div class="icon-box shadow-sm me-3"
                             style="background-color: white; color: var(--accent-blue);">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <p class="mb-0 text-muted">
                            A user interface designed for the classroom that provides easy
                            navigation for all users.
                        </p>
                    </li>

                    <li class="d-flex align-items-start mb-4">
                        <div class="icon-box shadow-sm me-3"
                             style="background-color: white; color: var(--accent-pink);">
                            <i class="fas fa-users"></i>
                        </div>
                        <p class="mb-0 text-muted">
                            Quick access tools and organized dashboards make the learning
                            environment modern.
                        </p>
                    </li>
                </ul>
            </div>

            <!-- Image Content -->
            <div class="col-md-6 position-relative">
                <!-- Decorative background elements if needed -->
                <div class="feature-img-wrapper">
                    <img src="~/Images/images/features3.png" class="img-fluid rounded-4" alt="UI Dashboard">
                </div>
            </div>
        </div>
    </div>
</section>
<section class="py-5 overflow-hidden">
    <div class="container">
        <div class="row align-items-center g-5">

            <!-- Text Content -->
            <div class="col-md-6 order-2 order-md-1">
                <h2 class="fw-bold mb-4" style="color: var(--primary);">
                    <span style="color: var(--secondary);">Tools</span> For Teachers <br> And Learners
                </h2>
                <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.8;">
                    Class, has a dynamic set of teaching tools built to be deployed and used during class.
                    Teachers can revitalize the lessons by using powerpoint, videos, and games.
                </p>
                <div class="d-flex align-items-center">
                    <p class="text-muted mb-0 me-3">Explore more tools</p>
                    <a href="#" class="btn rounded-circle shadow-sm"
                           style="background: white; color: var(--secondary); width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>

            <!-- Image Content with Decorative Shapes -->
            <div class="col-md-6 order-1 order-md-2 position-relative">
                <div class="tools-image-container">
                    <!-- The colorful decorative circles from the image -->
                    <div class="shape-circle bg-secondary"></div>
                    <div class="shape-circle bg-accent-purple"></div>

                    <img src="~/Images/images/tools1.png" class="img-fluid position-relative z-1" alt="Tools UI">
                </div>
            </div>

        </div>
    </div>
</section>
<section class="py-5" style="background-color: var(--bg-light);">
    <div class="container">
        <div class="row align-items-center g-5">
            <!-- Image with Decorative Circle -->
            <div class="col-md-6 position-relative">
                <div class="assessment-shape"></div>
                <img src="~/Images/images/assessments.png" class="img-fluid position-relative z-1" alt="Assessments">
            </div>
            <!-- Content -->
            <div class="col-md-6">
                <h2 class="fw-bold mb-4" style="color: var(--primary);">
                    Assessments, <br><span style="color: var(--secondary);">Quizzes</span>, Tests
                </h2>
                <p class="text-muted mb-0" style="font-size: 1.1rem; line-height: 1.8;">
                    Easily create and manage assessments to evaluate student performance.
                    Set time limits, manage question banks, and get instant results for your class.
                </p>
            </div>
        </div>
    </div>
</section>
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <!-- Content -->
            <div class="col-md-6">
                <h2 class="fw-bold mb-4" style="color: var(--primary);">
                    Class <span style="color: var(--secondary);">Management</span> <br>Tools for Educators
                </h2>
                <p class="text-muted mb-0" style="font-size: 1.1rem; line-height: 1.8;">
                    Manage students, track progress, and organize classes seamlessly.
                    Our tools give you total control over the learning environment with minimal effort.
                </p>
            </div>
            <!-- Image with Decorative Dots -->
            <div class="col-md-6 position-relative">
                <div class="management-dots"></div>
                <img src="~/Images/images/tools2.png" class="img-fluid position-relative z-1" alt="Management Tools">
            </div>
        </div>
    </div>
</section>
<section class="py-5" style="background-color: var(--bg-light);">
    <div class="container">
        <div class="row align-items-center g-5">
            <!-- Image with Accent Square -->
            <div class="col-md-6 position-relative">
                <div class="discussion-accent"></div>
                <img src="~/Images/images/ono-on-one.png" class="img-fluid position-relative z-1" alt="Discussions">
            </div>
            <!-- Content -->
            <div class="col-md-6">
                <h2 class="fw-bold mb-4" style="color: var(--primary);">
                    <span style="color: var(--secondary);">One-on-One</span> <br>Discussions
                </h2>
                <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.8;">
                    Enable meaningful conversations between students and instructors.
                    Private messaging and video calls make personalized learning possible from anywhere.
                </p>
                <button class="btn px-5 py-3 rounded-pill text-white" style="background-color: var(--secondary);">
                    See
                    more features
                </button>
            </div>
        </div>
    </div>
</section>
<section class="py-5">
    <div class="container">
        <h3 class="fw-bold mb-4">Explore Courses</h3>
        <div class="pill-stack d-flex flex-wrap justify-content-center gap-3 py-5">
            <div class="pill bg-orange" tabindex="0">
                <i class="fa-solid fa-code"></i>
                <span>Data Science</span>
            </div>

            <div class="pill bg-salmon" tabindex="0">
                <i class="fa-solid fa-palette"></i>
                <span>Creative Design</span>
            </div>

            <div class="pill bg-brown" tabindex="0">
                <i class="fa-solid fa-layer-group"></i>
                <span>UI/UX Design</span>
            </div>

            <div class="pill bg-gold" tabindex="0">
                <i class="fa-solid fa-globe"></i>
                <span>Web Development</span>
            </div>

            <div class="pill bg-purple" tabindex="0">
                <i class="fa-solid fa-bullhorn"></i>
                <span>Marketing</span>
            </div>

            <div class="pill bg-sky" tabindex="0">
                <i class="fa-solid fa-briefcase"></i>
                <span>Business</span>
            </div>

        </div>
    </div>
</section>

