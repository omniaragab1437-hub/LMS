@using LMSProject.ViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model LoginVM
<div class="container-fluid page-body-wrapper full-page-wrapper">
    <div class="content-wrapper d-flex align-items-center auth">
        <div class="row flex-grow">
            <div class="col-lg-4 mx-auto">
                <div class="auth-form-light text-left p-5">
                    <div class="brand-logo">
                        <img src="~/Admin/assets/images/logo.svg">
                    </div>
                    <h4>Hello! let's get started</h4>
                    <h6 class="font-weight-light">Sign in to continue.</h6>
                    <form method="post" class="pt-3">
                        <div class="form-group">
                            <input asp-for="EmailOrUsername"  type="email" class="form-control form-control-lg" id="exampleInputEmail1" placeholder="Email">
                            <span asp-validation-for="EmailOrUsername" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <input asp-for="Password" type="password" class="form-control form-control-lg" id="exampleInputPassword1" placeholder="Password">
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-block btn-gradient-primary btn-lg font-weight-medium auth-form-btn" >SIGN IN</button>
                        </div>
                        <div class="my-2 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <label class="form-check-label text-muted">
                                    <input type="checkbox" asp-for="RememberMe" class="form-check-input"> Keep me signed in <i class="input-helper"></i>
                                </label>
                            </div>
                            <a asp-action="ForgotPassword" asp-controller="Account" class="auth-link text-black">Forgot password?</a>
                        </div>
                        
                        <div class="text-center mt-4 font-weight-light">
                            Don't have an account? <a asp-controller="Account"
                                                      asp-action="Register" class="text-primary">Create</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- content-wrapper ends -->
</div>