@using LMSProject.ViewModel
@{
}
@model LoginVM

<!-- Logo Section -->
<div class="d-flex justify-content-center align-content-center pt-3 pb-0">
    <a asp-controller="Default" asp-action="Index" style="cursor: pointer;">
        <img src="~/Images/images/logo_black.png" alt="Logo" style="height: 60px;">
    </a>
</div>

<!-- Auth Container -->
<div class="container auth-wrapper mt-0">
    <div class="row auth-card w-100">

        <!-- LEFT IMAGE (Hidden on mobile) -->
        <div class="col-md-6 p-0 d-none d-md-block">
            <img src="~/Images/images/student.jpeg" class="w-100 auth-image" alt="Login Banner" />
        </div>

        <!-- RIGHT SIDE - LOGIN FORM -->
        <div class="col-md-6 bg-white p-5 d-flex flex-column justify-content-center">

            <!-- Welcome Text -->
            <h6 class="text-center mb-3 text-dark fw-bold">
                Welcome to LMS!
            </h6>

            <!-- ROLE TOGGLE SECTION (COMMENTED FOR FUTURE USE) -->
            @*
            <div class="role-switch mx-auto mb-3">
                <div class="switch-track">
                    <div class="switch-slider"></div>
                    <button type="button" class="active-text">Student</button>
                    <button type="button">Parent</button>
                    <button type="button">Teacher</button>
                    <button type="button">Admin</button>
                </div>
            </div>

            <p class="text-center text-muted small mb-4">
                Sign in as <b>Student</b>
            </p>
            *@

            <!-- LOGIN FORM -->
            <form method="post" novalidate>

                <!-- USERNAME/EMAIL INPUT -->
                <div class="mb-3">
                    <input asp-for="EmailOrUsername" type="text" class="form-control auth-input" 
                        placeholder="Username or Email" required />
                    <span asp-validation-for="EmailOrUsername" class="text-danger small"></span>
                </div>

                <!-- PASSWORD INPUT -->
                <div class="mb-3">
                    <input asp-for="Password" type="password" class="form-control auth-input" 
                        placeholder="Password" required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- REMEMBER ME & FORGOT PASSWORD -->
                <div class="d-flex justify-content-between small mb-3">
                    <label>
                        <input type="checkbox" asp-for="RememberMe"> Remember me
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="text-decoration-none text-primary">
                        Forgot password?
                    </a>
                </div>

                <!-- SIGN IN BUTTON -->
                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
                    Sign In
                </button>

            </form>

            <!-- Sign Up Link -->
            <p class="text-center small text-muted mt-4">
                Don't have an account? 
                <a asp-controller="Account" asp-action="Register" class="text-decoration-none text-primary fw-bold">
                    Create one
                </a>
            </p>

        </div>

    </div>
</div>

